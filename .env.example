# ========================================
# A股量化交易系统 · 环境变量模板
# 复制为 .env 并填入实际值
# ========================================

# Tushare Pro Token（必填）
TUSHARE_TOKEN=your_tushare_token_here

# ClickHouse
CH_HOST=localhost
CH_PORT=9000
CH_USER=default
CH_PASSWORD=

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 日志级别
LOG_LEVEL=INFO

# 企业微信告警（可选）
WECHAT_WEBHOOK=
